{% if realms|length > 1 %}
			<fieldset id="realm-picker">
				<legend accesskey="r">{{ t('Realm') }}</legend>
				<ul>

{% for realm in realms %}
					<li>
						<input type="radio" name="realm" value="{{ realm.realm_id }}" id="realm_{{ realm.realm_id }}" required>
						<label for="realm_{{ realm.realm_id }}"><strong>{{ t(realm.display_name) }}</strong> <small>{{ realm.realm_id }}</small>
{% if realm.description %}
							<br>{{ t(realm.description) }}
{% endif %}
						</label>
{% endfor %}
				</ul>
			</fieldset>
{% endif %}
