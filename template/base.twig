<!DOCTYPE html>
<html lang="{{ _locale }}" class="{% block documentClass %}{% endblock %}">
<link rel="stylesheet" href="{{ _basePath }}/assets/letswifi.css">
{% if _branding_css_file %}
<link rel="stylesheet" href="{{ _basePath }}/assets/branding/{{ _product_shortname }}/{{ _branding_css_file }}">
{% endif %}
{% if _branding_favicon_file %}
<link rel="icon" href="{{ _basePath }}/assets/branding/{{ _product_shortname }}/{{ _branding_favicon_file }}">
{% endif %}
<meta name="viewport" content="width=device-width, initial-scale=1">
{% if meta_redirect %}
<meta http-equiv="refresh" content="0; url={{ meta_redirect }}">
{% endif %}
<title>{{ _product_name }} - {% block title %}{% endblock %}</title>
<header>
	{% block header %}<span id="product-name" aria-hidden>{{ _product_name }}</span>{% endblock %}
	<details id="language-chooser">
		<summary>{{ t(_locale) }}</summary>
		<ul class="dropdown" id="languages">
	{% for displayName, locale in _supportedLocales %}
	{% if locale == _locale %}
			<li lang="{{ locale }}"><strong>{{ displayName }}</strong></li>
	{% else %}
			<li lang="{{ locale }}"><a draggable="false" href="?lang={{ locale|split('-', 2)|first }}">{{ displayName }}</a></li>
	{% endif %}
	{% endfor %}
		</ul>
	</details>
	<details id="user-chooser">
		<summary>{{ _user ? t('Logged in') : t('User') }}</summary>
		<ul class="dropdown" id="user-options">
		{% if _user %}
			<li><a draggable="false" class="oojs-icon oojs-icon-userContributions" href="{{ _basePath }}/me/">{{ t('User information') }}</a></li>
			{% if _logout_href %}
			<li><a draggable="false" class="oojs-icon oojs-icon-logout" href="{{ _logout_href }}">{{ t('Logout') }}</a></li>
			{% endif %}
		{% else %}
			<li><a draggable="false" class="oojs-icon oojs-icon-login" href="{{ _login_href ?? _basePath ~ '/me/' }}">{{ t('Login') }}</a></li>
		{% endif %}
		</ul>
	</details>
</header>
{% block layout %}{% endblock %}
