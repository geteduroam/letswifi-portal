				{% for app_id, app in platform.apps %}
					{% if app_id == 'play-store' %}
						<li class="play-store {{ app.type }} badge"><a href="{{ app.href }}"><img src="/assets/badge/play-store/{{ 'Google_Play_Store_badge_EN.svg'|translate_raw }}" alt="{{ 'Get it on Google Play'|translate_raw }}"></a></li>
					{% elseif app_id == 'app-store' %}
						<li class="app-store {{ app.type }} badge"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener"><img src="/assets/badge/app-store/{{ 'Download_on_the_App_Store_Badge_US-UK_RGB_blk_092917.svg'|translate_raw }}" alt="{{ 'Download on the App Store'|translate_raw }}"></a></li>
					{% elseif app_id == 'app-gallery' %}
						<li class="app-gallery {{ app.type }} badge"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener"><img src="/assets/badge/app-gallery/huawei-Badge-Black.png" alt="{{ 'Explore it on AppGallery'|translate_raw }}"></a></li>
					{% elseif app_id == 'f-droid' %}
						<li class="f-droid {{ app.type }} badge"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener"><img src="/assets/badge/f-droid/{{ 'get-it-on-en.svg'|translate_raw }}" alt="{{ 'Get it on F-Droid'|translate_raw }}"></a></li>
					{% elseif app_id == 'microsoft-store' %}
						<li class="microsoft-store {{ app.type }} badge"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener"><picture>
							<source srcset="/assets/badge/microsoft-store/{{ 'en-us%%20%s.svg'|translate_raw('dark') }}" media="(prefers-color-scheme: dark)"/>
							<img src="/assets/badge/microsoft-store/{{ 'en-us%%20%s.svg'|translate_raw('light') }}" alt="{{ 'Download from the Microsoft Store'|translate_raw }}">
						</picture></a></li>
					{% elseif app_id == 'flathub' %}
						<li class="flathub {{ app.type }} badge"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener"><img src="/assets/badge/flathub/{{ 'badge-en.svg'|translate_raw }}" alt="{{ 'Get it on Flathub'|translate_raw }}"></a></li>
					{% elseif app.type == 'download' %}
						{# Since app.href is probably cross-domain, the custom download= won't actually work #}
						<li class="{{ app_id }} {{ app.type }}"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener" download="{{ app.href|split('?')|first|split('/')|last }}"><span><span class="platform">{{ platform.name }}</span><span>{{ app.name }}</span></span></a></li>
					{% else %}
						<li class="{{ app_id }} {{ app.type }}"><a href="{{ app.href }}" rel="nofollow,noreferrer,noopener">{{ app.name }}</a></li>
					{% endif %}
				{% endfor %}
