{% extends 'menu.twig' %}

{% block title %}{{ 'Account information'|translate_raw }}{% endblock %}

{% block content %}
<main>
	<section class="user highlight">
		<h1>{{ 'Account information'|t }}</h1>
		<dl>
			<dt>{{ 'User ID'|t }}</dt>
			<dd><code>{{ user.user_id }}</code></dd>
		</dl>
{% if user.affiliations %}
		<dl>
			<dt>{{ 'Affiliations'|t }}</dt>
			<dd>
				<ul>
{% for affiliation in user.affiliations %}
					<li><code>{{ affiliation }}</code></li>
{% endfor %}
				</ul>
			</dd>
		</dl>
		<p>
			{{ 'User information is not stored after you log out.'|t }}
			{{ 'User ID is connected to credentials while they are valid and short time thereafter.'|t }}
{% endif %}
	</section>
	<section class="realms" id="realm-picker">
		<h1>{{ 'Available realms'|t }}</h1>
{% if realms %}
			<ul>

{% for realm in realms %}
				<li>
{% if realm.logo_endpoint %}
					<img src="{{ realm.logo_endpoint }}" alt="Logo" aria-hidden="true">
{% endif %}
					<strong>{{ realm.display_name|t }}</strong>
					<small>{{ realm.realm_id }}</small>
{% if realm.description %}
					<br>{{ realm.description|t }}
{% endif %}
				</li>
{% endfor %}
			</ul>
{% else %}
			<p>{{ 'No realms available'|t }}</p>
{% endif %}

	</section>

	<form method="POST" action="{{ form_action }}">
		<h1>{{ 'Authorised applications'|t }}</h1>
{% if grants %}
		<table>
			<tr>
				<th>{{ 'Client ID'|t }}</th>
				<th>{{ 'Issued'|t }}</th>
				<th>{{ 'Expires'|t }}</th>
			</tr>
{% for grant in grants %}
			<tr>
				<td>{{ grant.client_id }}</td>
				<td>{{ grant.not_before|split('T', 2)|first }}</td>
				<td>{{ grant.not_after|split('T', 2)|first }}</td>
				<td><button class="btn-danger" name="revoke_grant" value="{{ grant.session_id }}">{{ 'Revoke'|t }}</button></td>
			</tr>
{% endfor %}
		</table>
		{% else %}
		<p>{{ 'No authorised applications'|t }}
		{% endif %}
	</form>

	<form method="POST" action="{{ form_action }}">
		<h1>{{ 'Credentials'|t }}</h1>
{% if credentials %}
		<table>
			<tr>
				<th>{{ 'Credential'|t }}</th>
				<th>{{ 'Issued'|t }}</th>
				<th>{{ 'Expires'|t }}</th>
			</tr>
{% for credential in credentials %}
			<tr>
				<td><span class="{{ credential.revoked ? 'revoked' : '' }}">{{ credential.credential_id }}</span></td>
				<td>{{ credential.not_before|split('T', 2)|first }}</td>
				<td>{{ credential.not_after|split('T', 2)|first }}</td>
				<td><button class="btn-danger" name="revoke_credential" value="{{ credential.credential_id }}">{{ 'Revoke'|t }}</button></td>
			</tr>
{% endfor %}
		</table>
		{% else %}
		<p>{{ 'No credentials'|t }}
		{% endif %}
	</form>
</main>
{% endblock %}
