{% extends 'admin.twig' %}

{% block title %}{{ 'Administration panel'|translate_raw }}{% endblock %}

{% block admin_content %}
	<section class="highlight">
	<form>
		<details open class="form">
		<summary>{{ 'Search'|t }}</summary>
			<dl>
				<dt>{{ 'Valid on'|t }}</dt>
				<dd><input type="datetime-local" name="valid_on" value="{{ filter_valid_on|split('+')|first }}"></dd>
			</dl>
			<dl>
				<dt>{{ 'Username'|t }}</dt>
				<dd>
					<input type="text" name="requester" value="{{ filter_requester }}">
				</dd>
			</dl>
			<dl>
				<dt>{{ 'Realms'|t }}</dt>
				<dd class="realm-checkboxes">
					{% for realm in realms %}
					<span class="realm-checkbox">
					<input type="checkbox" id="realm_{{ realm.realm_id }}" name="realms[]" value="{{ realm.realm_id }}"{{ not filter_realms or realm.realm_id in filter_realms ? ' checked' : '' }}>
					<label for="realm_{{ realm.realm_id }}">{{ realm.realm_id }}</label>
					</span>
					{% endfor %}
				</dd>
			</dl>

			<p><button type="submit">{{ 'Search'|t }}</button>
		</details>
	</form>
	</section>

	<hr>

	{% if credentials %}
	<form method="POST"><input type="hidden" name="valid_on" value="{{ filter_valid_on|split('+')|first }}">
		<table>
			<tr>
				<th>{{ 'Requester'|t }}</th>
				<th>{{ 'Ident'|t }}</th>
				<th>{{ 'Issued'|t }}</th>
				<th>{{ 'Expires'|t }}</th>
				<th>{{ 'Revoked'|t }}</th>
				<th></th>
			</tr>
			{% for credential in credentials %}
			<tr>
				<td><a href="{{ credential.requester_href }}">{{ credential.requester.user_id }}</a>@<a href="{{ credential.realm_href }}">{{ credential.realm.realm_id }}</a></td>
				<td>{{ credential.credential_id }}</td>
				<td>{{ credential.not_before }}</td>
				<td>{{ credential.not_after }}</td>
				<td>
					{% if credential.revoked %}
					{{ credential.revoked }}
					{% else %}
					<button class="btn-danger" name="revoke_credential" value="{{ credential.credential_id }}">{{ 'Revoke'|t }}</button>
					{% endif %}
				</td>
			</tr>
			{% endfor %}
		</table>
	</form>
	{% else %}
	<p>{{ 'No results'|t }}
	{% endif %}
{% endblock %}
