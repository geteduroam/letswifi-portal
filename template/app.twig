{% extends 'menu.twig' %}

{% block title %}{{ 'Apps'|translate_raw }}{% endblock %}

{% block content %}
	<main>
		<h1>{{ 'All installer apps'|t }}</h1>
		{% for platform in platforms|sort((a, b) => a.match ? -1 : (b.match ? 1 : a.name|lower <=> b.name|lower)) %}
			<section class="{{ platform.match == true ? 'highlight' : '' }}">
			<h2>{{ platform.name }}</h2>
			{% if platform.apps %}
				<ul class="apps buttons">
				{% for app_id, app in platform.apps %}
					<li class="{{ app_id }} {{ app.type }}"><a class="btn btn-default" href="{{ app.href }}" rel="nofollow,noreferrer,noopener">{{ app.name }}</a></li>
				{% endfor %}
				</ul>
			{% endif %}
			{% if platform.profiles %}
				{% if platform.apps %}
					<details><summary>{{ 'If you cannot use the official app, you can download an installation profile for manual installation.'|t }}</summary>
					<p>
				{% else %}
					<p>
						{{ 'There is no app available for %s.'|t(platform.name) }}<br>
						{{ 'Download an installation profile for manual installation.'|t }}
				{% endif %}
				{% for profile in platform.profiles %}
					<a href="{{ profile.href }}">{{ profile.name }}</a>
				{% endfor %}
				{% if platform.apps %}
					</details>
				{% endif %}
			{% endif %}
			</section>
		{% endfor %}

		<section class="platform-other">
		<h1>{{ 'Other options'|t }}</h1>
		<details>
			<summary>{{ 'Options for other platforms and professional users'|t }}</summary>
			<p><a href="{{ advanced_href }}">{{ 'Generate a certificate for manual use'|t }}</a></p>
		</details>
		</section>
	</main>
{% endblock %}
