{% extends 'menu.twig' %}

{% block title %}{{ tattr('Apps') }}{% endblock %}

{% block content %}
	<main>
		<h1>{{ t('All installer apps') }}</h1>
		{% for platform in platforms|sort((a, b) => a.match ? -1 : (b.match ? 1 : a.name|lower <=> b.name|lower)) %}
			<section class="{{ platform.match == true ? 'highlight' : '' }}">
			<h2>{{ platform.name }}</h2>
			{% if platform.apps %}
				<ul class="apps buttons">
				{{ include('_app-button.twig') }}
				</ul>
			{% endif %}
			{% if platform.profiles %}
				{% if platform.apps %}
					<details><summary>{{ t('If you cannot use the official app, you can download an installation profile for manual installation.') }}</summary>
					<p>
				{% else %}
					<p>
						{{ t('There is no app available for %s.', platform.name) }}<br>
						{{ t('Download an installation profile for manual installation.') }}
				{% endif %}
				{% for profile in platform.profiles %}
					<a href="{{ profile.href }}">{{ profile.name }}</a>
				{% endfor %}
				{% if platform.apps %}
					</details>
				{% endif %}
			{% endif %}
			</section>
		{% endfor %}

		<section class="platform-other">
		<h1>{{ t('Other options') }}</h1>
		<details>
			<summary>{{ t('Options for other platforms and professional users') }}</summary>
			<p><a href="{{ advanced_href }}">{{ t('Generate a certificate for manual use') }}</a></p>
		</details>
		</section>
	</main>
{% endblock %}
